<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <h1>Find Distance between lat long</h1>
    <div></div>
    <div>
        <p>from latlong</p>
        <button id="btnGetCoord" >get my coordinates</button>
        <input type="text" id="fromLat" placeholder="from latitude" >
        <input type="text" id="fromLong" placeholder="from Longitude" >
        <p>to latlong</p>
        <input type="text" id="toLat" placeholder="to latitude" >
        <input type="text" id="toLong" placeholder="to Longitude" >
        <br>
        <button onclick="calcDistance()">Calculate</button>

        <p id="distanceKm"></p>
    </div>
</body>
<script>
    const btn = document.getElementById("btnGetCoord");
    btn.addEventListener("click", ()=>{
        console.log("clicked");
        navigator.geolocation.getCurrentPosition((data)=>{
            console.log(data);
            
            document.getElementById("fromLat").value = data.coords.latitude;
            document.getElementById("fromLong").value = data.coords.longitude;

        });
    })
    function calcDistance(){
        let lat1 = document.getElementById("fromLat").value;
        let lon1 = document.getElementById("fromLong").value;
        let lat2 = document.getElementById("toLat").value;
        let lon2 = document.getElementById("toLong").value;
        
        const R = 6371e3;
        const φ1 = lat1 * Math.PI/180; 
        const φ2 = lat2 * Math.PI/180;
        const Δφ = (lat2-lat1) * Math.PI/180;
        const Δλ = (lon2-lon1) * Math.PI/180;

        const a = Math.sin(Δφ/2) * Math.sin(Δφ/2) +
                Math.cos(φ1) * Math.cos(φ2) *
                Math.sin(Δλ/2) * Math.sin(Δλ/2);
        const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a));

        const distancem = R * c; // in metres

        console.log(distancem);

        document.getElementById("distanceKm").innerText = `${(distancem/1000).toFixed(2) }KM`;

    }
</script>
</html>